  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register user",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"user\": {\n    \"username\": \"{{username}}\",\n    \"email\": \"{{email}}\",\n    \"password\": \"{{password}}\"\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/users",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "users"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.response.to.have.status(201);",
                  "const json = pm.response.json();",
                  "pm.expect(json).to.have.property('user');",
                  "pm.expect(json.user).to.have.property('token');",
                  "pm.expect(json.user.username).to.eql(pm.collectionVariables.get('username'));",
                  "pm.collectionVariables.set('token', json.user.token);"
                ]
              }
            }
          ]
        },
        {
